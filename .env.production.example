# local = no backend required, browser localStorage only.
# api = use VITE_API_URL and the Nest backend.
VITE_STORAGE_MODE=local

# Use this when Nginx serves the frontend and proxies /api to the backend.
VITE_API_URL=https://assethub.skynesys.com/api

# If you deploy the API on a dedicated subdomain, use this instead:
# VITE_API_URL=https://api.assethub.skynesys.com/api